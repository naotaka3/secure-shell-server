{
  "allowedDirectories": ["/home", "/tmp", "/var/log"],
  "allowCommands": [
    "ls",
    "cat",
    "echo",
    "grep",
    "find",
    "head",
    "tail",
    {
      "command": "git",
      "subCommands": [
        "status",
        "pull",
        "fetch",
        "log",
        "diff",
        {
          "name": "push",
          "denyFlags": ["-f", "--force", "--force-with-lease"],
          "message": "Force push is not allowed"
        },
        {
          "name": "branch",
          "denyFlags": ["-D"],
          "message": "Force branch deletion is not allowed, use -d instead"
        }
      ],
      "denySubCommands": ["reset --hard"]
    },
    {
      "command": "docker",
      "subCommands": [
        "ps",
        "logs",
        "info",
        "inspect",
        {
          "name": "compose",
          "subCommands": [
            {
              "name": "up",
              "denyFlags": ["--force-recreate"]
            },
            "down",
            "logs",
            "ps"
          ]
        }
      ]
    }
  ],
  "denyCommands": [
    {
      "command": "rm",
      "message": "Run `git rm` instead of rm"
    },
    {
      "command": "cd",
      "message": "Specify directory in arguments instead of using cd"
    },
    {
      "command": "sudo",
      "message": "Elevated privileges are not allowed"
    }
  ],
  "defaultErrorMessage": "This command is not allowed.",
  "blockLogPath": "/var/log/secure-shell/blocked-commands.log",
  "maxExecutionTime": 60,
  "maxOutputSize": 51200
}
